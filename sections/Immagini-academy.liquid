      "type": "range",
      "id": "gap_mobile",
      "label": "Spazio tra le card (mobile)",
      "min": 4,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "title_size_mobile",
      "label": "Dimensione titolo card (mobile)",
      "min": 12,
