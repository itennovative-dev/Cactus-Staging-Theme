        { "value": "h3", "label": "Medio" },
        { "value": "h2", "label": "Grande" },
        { "value": "h1", "label": "Extra grande" }
      ],
      "default": "h2"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Allineamento intestazione",
      "options": [
        { "value": "left", "label": "Sinistra" },
        { "value": "center", "label": "Centro" },
        { "value": "right", "label": "Destra" }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Impostazioni mobile"
    },
    {
      "type": "select",
      "id": "aspect_ratio_mobile",
