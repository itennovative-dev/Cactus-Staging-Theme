<style>
  #shopify-section-{{ section.id }} {
    background: #f9f8f2;
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  #shopify-section-{{ section.id }} .grid-cards-title {
    display: grid;
    grid-template-columns: repeat({{ section.settings.desktop_columns }}, 1fr);
    gap: {{ section.settings.gap }}px;
  }

  #shopify-section-{{ section.id }} .grid-card-title__item {
    display: flex;
    flex-direction: column;
    gap: 10px;
    text-decoration: none;
    color: inherit;
  }

  #shopify-section-{{ section.id }} .grid-card-title__media {
    position: relative;
    overflow: hidden;
    border-radius: {{ section.settings.border_radius }}px;
    aspect-ratio: {{ section.settings.aspect_ratio }};
    background: var(--color-background-secondary, #f0f0f0);
    border: 2px solid transparent;
    transition: border-color 0.2s ease;
  }


  #shopify-section-{{ section.id }} .grid-card-title__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  #shopify-section-{{ section.id }} .grid-card-title__item:hover .grid-card-title__image {
    transform: scale(1.03);
  }

  #shopify-section-{{ section.id }} .grid-card-title__placeholder {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  #shopify-section-{{ section.id }} .grid-card-title__placeholder .placeholder-svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  #shopify-section-{{ section.id }} .grid-card-title__label {
    max-width: 261px;
    font-size: {{ section.settings.title_size }}px;
    font-weight: {{ section.settings.title_weight }};
    line-height: 1.3;
    color: {{ section.settings.title_color }};
    margin: 0;
    padding-left: 15px;
  }

  @media screen and (max-width: 767px) {
    #shopify-section-{{ section.id }} .grid-cards-title {
      grid-template-columns: repeat({{ section.settings.mobile_columns }}, 1fr);
      gap: {{ section.settings.gap_mobile }}px;
    }

    #shopify-section-{{ section.id }} .grid-card-title__label {
      font-size: {{ section.settings.title_size_mobile }}px;
    }
  }
</style>

<div class="grid-cards-title-section section--padding">
  <div class="{% if section.settings.container == 'full' %}w-full{% else %}page-width{% endif %}">

    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <div class="section-header text-{{ section.settings.heading_alignment }} mb-8">
        {%- if section.settings.subheading != blank -%}
          <motion-element data-motion="fade-up" class="block text-subheading">
            {{ section.settings.subheading }}
          </motion-element>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <motion-element data-motion="fade-up" data-motion-delay="50" class="block">
            <h2 class="{{ section.settings.heading_size }}">{{ section.settings.heading }}</h2>
          </motion-element>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="grid-cards-title">
      {%- for block in section.blocks -%}
        {%- if block.type == 'card' -%}
          {%- liquid
            assign is_active = false
            if forloop.first and section.settings.highlight_first
              assign is_active = true
            endif
          -%}
          <motion-element
            data-motion="fade-up"
            data-motion-delay="{{ forloop.index0 | times: 60 }}"
            {{ block.shopify_attributes }}
          >
            {%- if block.settings.link != blank -%}
              <a
                href="{{ block.settings.link }}"
                class="grid-card-title__item{% if is_active %} grid-card-title__item--active{% endif %}"
                aria-label="{{ block.settings.title }}"
              >
            {%- else -%}
              <div class="grid-card-title__item{% if is_active %} grid-card-title__item--active{% endif %}">
            {%- endif -%}

              <div class="grid-card-title__media">
                {%- if block.settings.image != blank -%}
                  {%- capture sizes -%}
                    (max-width: 767px) calc(100vw / {{ section.settings.mobile_columns }} - {{ section.settings.gap_mobile }}px),
                    calc(min({{ settings.page_width }}px, 100vw) / {{ section.settings.desktop_columns }} - {{ section.settings.gap }}px)
                  {%- endcapture -%}
                  {{
                    block.settings.image
                    | image_url: width: block.settings.image.width
                    | image_tag:
                      loading: 'lazy',
                      sizes: sizes,
                      widths: '200,300,400,500,600,800',
                      class: 'grid-card-title__image',
                      is: 'image-lazy',
                      alt: block.settings.title
                  }}
                {%- else -%}
                  <div class="grid-card-title__placeholder">
                    {{- 'image' | placeholder_svg_tag: 'placeholder-svg' -}}
                  </div>
                {%- endif -%}
              </div>

              {%- if block.settings.title != blank -%}
                <p class="grid-card-title__label">{{ block.settings.title }}</p>
              {%- endif -%}

            {%- if block.settings.link != blank -%}
              </a>
            {%- else -%}
              </div>
            {%- endif -%}
          </motion-element>
        {%- endif -%}
      {%- endfor -%}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Grid cards con titolo",
  "settings": [
    {
      "type": "header",
      "content": "Generale"
    },
    {
      "type": "select",
      "id": "container",
      "label": "t:sections.all.container.label",
      "options": [
        { "value": "full", "label": "t:sections.all.container.options__full.label" },
        { "value": "fixed", "label": "t:sections.all.container.options__fixed.label" }
      ],
      "default": "fixed"
    },
    {
      "type": "select",
      "id": "desktop_columns",
      "label": "Colonne (desktop)",
      "options": [
        { "value": "2", "label": "2 colonne" },
        { "value": "3", "label": "3 colonne" },
        { "value": "4", "label": "4 colonne" },
        { "value": "5", "label": "5 colonne" }
      ],
      "default": "4"
    },
    {
      "type": "select",
      "id": "mobile_columns",
      "label": "Colonne (mobile)",
      "options": [
        { "value": "1", "label": "1 colonna" },
        { "value": "2", "label": "2 colonne" }
      ],
      "default": "2"
    },
    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "Proporzioni immagine",
      "options": [
        { "value": "16/9", "label": "16:9" },
        { "value": "4/3", "label": "4:3" },
        { "value": "3/2", "label": "3:2" },
        { "value": "1/1", "label": "1:1 Quadrata" }
      ],
      "default": "4/3"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Spazio tra card (desktop)",
      "min": 4,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "gap_mobile",
      "label": "Spazio tra card (mobile)",
      "min": 4,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 10
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Arrotondamento angoli",
      "min": 0,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 10
    },
    {
      "type": "header",
      "content": "Stile"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Colore titolo card",
      "default": "#1a5c52"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Dimensione titolo (desktop)",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "title_size_mobile",
      "label": "Dimensione titolo (mobile)",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "select",
      "id": "title_weight",
      "label": "Peso font titolo",
      "options": [
        { "value": "400", "label": "Normale" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semibold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "500"
    },
    {
      "type": "color",
      "id": "active_border_color",
      "label": "Colore bordo attivo / hover",
      "default": "#2b7fff"
    },
    {
      "type": "checkbox",
      "id": "highlight_first",
      "label": "Evidenzia prima card come attiva",
      "default": false
    },
    {
      "type": "header",
      "content": "Intestazione sezione (opzionale)"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Sottotitolo"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Titolo sezione"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Dimensione titolo sezione",
      "options": [
        { "value": "h4", "label": "Piccolo" },
        { "value": "h3", "label": "Medio" },
        { "value": "h2", "label": "Grande" },
        { "value": "h1", "label": "Extra grande" }
      ],
      "default": "h2"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Allineamento intestazione",
      "options": [
        { "value": "left", "label": "Sinistra" },
        { "value": "center", "label": "Centro" },
        { "value": "right", "label": "Destra" }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:sections.all.padding.padding_top",
      "default": 40,
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 40,
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Immagine"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titolo",
          "default": "Come usare le Dual Form by Cactus For You"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (opzionale)"
