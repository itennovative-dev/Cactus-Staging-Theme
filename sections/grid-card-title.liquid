  ],
  "presets": [
    {
      "name": "Grid cards con titolo",
      "blocks": [
        { "type": "card", "settings": { "title": "Come usare le Dual Form by Cactus For You" } },
        { "type": "card", "settings": { "title": "Come usare le Dual Form by Cactus For You" } },
        { "type": "card", "settings": { "title": "Come usare le Dual Form by Cactus For You" } },
        { "type": "card", "settings": { "title": "Come usare le Dual Form by Cactus For You" } },
        { "type": "card", "settings": { "title": "Come usare le Dual Form by Cactus For You" } },
        { "type": "card", "settings": { "title": "Come usare le Dual Form by Cactus For You" } },
        { "type": "card", "settings": { "title": "Come usare le Dual Form by Cactus For You" } },
        { "type": "card", "settings": { "title": "Come usare le Dual Form by Cactus For You" } }
      ]
    }
  ],
  "disabled_on": {
