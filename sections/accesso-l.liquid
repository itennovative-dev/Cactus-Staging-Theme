{% assign has_accesso_liquid = false %}
{% if customer %}
  {% for tag in customer.tags %}
    {% assign clean_tag = tag | strip | downcase %}
    {% if clean_tag == 'accesso-liquid' %}
      {% assign has_accesso_liquid = true %}
      {% break %}
    {% endif %}
  {% endfor %}
{% endif %}

