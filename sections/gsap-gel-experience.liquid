(function enableHueClickJump(){
  if (!hueRange) return;

  const setFromPointer = (clientY) => {
    const r = hueRange.getBoundingClientRect();
    const min = parseFloat(hueRange.min) || 0;
    const max = parseFloat(hueRange.max) || 359;
    
    let t = (clientY - r.top) / r.height;
    t = Math.max(0, Math.min(1, t));
    
    const val = Math.round(max - (t * (max - min)));
    
    hueRange.value = val;
    hueRange.dispatchEvent(new Event('input', { bubbles: true }));
  };

  const onDown = (e) => {
    e.preventDefault();
    e.stopPropagation();
    setFromPointer(e.clientY);
    
    const move = (ev) => {
      ev.preventDefault();
      setFromPointer(ev.clientY);
    };
    
    const up = () => {
      window.removeEventListener('pointermove', move);
      window.removeEventListener('pointerup', up, { capture:true });
    };
    
    window.addEventListener('pointermove', move, { passive: false });
    window.addEventListener('pointerup', up, { capture:true, once:true });
  };

  hueRange.addEventListener('pointerdown', onDown, { passive: false });
})();

