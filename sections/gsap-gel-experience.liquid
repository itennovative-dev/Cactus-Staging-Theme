document.addEventListener('DOMContentLoaded', () => {

   handleCartDrawerFromQuery();
/* ==== Drawer helpers: open/close/toggle senza conflitti ==== */

function getGaps(){
  const VISIBLE_X = 5;
  const GAP_X = VISIBLE_X + 0;
  const GAP_Y = -6;
  return { GAP_X, GAP_Y };
}
function getCardMetrics(){
  const W = getImgWidth();
  const CARD_W = W - 40;
  const GAP = getGap();
  const IMG_OVERHANG = 20;
  const SHADOW_SAFE  = 16;
  const RIGHT_SAFE   = IMG_OVERHANG + SHADOW_SAFE;
  const LEFT_SAFE    = 20;
  const IMG_H  = Math.round(W * 1.10);
  const META_H = 10;
  const CARD_H = IMG_H + META_H;
  return { W, CARD_W, GAP, CARD_H, LEFT_SAFE, RIGHT_SAFE };
}


function getCartDrawer(){
  return document.getElementById('CartDrawer') ||
         document.querySelector('cart-drawer, .cart-drawer, [data-cart-drawer]');
}
function isCartDrawerOpen(){
  const d = getCartDrawer();
  if (!d) return false;
  if (typeof d.isOpen === 'boolean') return d.isOpen;
  return d.hasAttribute('open') || d.classList.contains('is-open') ||
         d.classList.contains('active') || d.matches('[open]');
}
function openCartDrawer(silent = false){
  if (!silent) {
    document.documentElement.dispatchEvent(new CustomEvent('cart:open'));
  }
  const d = getCartDrawer();
  if (!d) return;
  if (typeof d.open === 'function') d.open();
  else { d.setAttribute('open',''); d.classList.add('is-open','active'); }
}

function closeCartDrawer(){
  document.documentElement.dispatchEvent(new CustomEvent('cart:close'));
  const d = getCartDrawer();
  if (!d) return;
  if (typeof d.close === 'function') d.close();
  else { d.removeAttribute('open'); d.classList.remove('is-open','active'); }
}


function sectionExists(id){
  return document.getElementById(id) || document.querySelector(`[data-section-id="${id}"]`);
}

function replaceSectionHtml(id, html){
  const target = document.getElementById(id) || document.querySelector(`[data-section-id="${id}"]`);
  if (!target || !html) return;
  const tmp = document.createElement('div');
  tmp.innerHTML = html.trim();
  const fresh = tmp.firstElementChild || tmp;
  target.replaceWith(fresh);
}

function getSectionId(el){
  if (!el) return null;
  return el.getAttribute?.('data-section-id') || el.getAttribute?.('section-id') || el.id || null;
}

async function refreshCartSections(opts = {}){
  const ROOT = (window.Shopify && Shopify.routes && Shopify.routes.root) || '/';
  const includeDrawer = !!opts.includeDrawer;

  const ids = new Set();

  const headerEl =
    document.querySelector('header[section-id], header[data-section-id]') ||
    document.querySelector('.shopify-section-header, .section-header, header.shopify-section') ||
    document.querySelector('header[id]');
  const headerId = getSectionId(headerEl);
  if (headerId) ids.add(headerId);

  const drawerEl =
    document.getElementById('CartDrawer') ||
    document.querySelector('#CartDrawer, cart-drawer, .shopify-section[id*="cart"], [data-section-id*="cart"]');
  const drawerId = getSectionId(drawerEl);

  if (!ids.size) return false;

  const onCartPage = location.pathname.replace(ROOT,'/').startsWith('/cart');
  const path = onCartPage ? 'cart' : '';
  const url = `${ROOT}${path}?sections=${[...ids].join(',')}&_=${Date.now()}`;

  const res = await fetch(url, { credentials:'include', headers:{ 'Accept':'application/json' }});
  if (!res.ok) return false;

  const htmlById = await res.json();
  [...ids].forEach(id => replaceSectionHtml(id, htmlById[id]));

  return true;
}
