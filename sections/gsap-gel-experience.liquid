  /* Stato canvas */
let panX = 0;
let panY = 0;
let ZOOM = parseFloat(zoomRange?.value || '0.9') || 0.9;
let contentW = 1000;
let contentH = 1000;

const META_H = 10;
const PAD_TOP = 8;
const PAD_BOTTOM = 84;
const VIEWPORT_RIGHT_MARGIN = 20;

function clampPanXY(px, py) {
  const { LEFT_SAFE, RIGHT_SAFE } = getCardMetrics();
  const vw = stage.clientWidth || window.innerWidth;
  const vh = stage.clientHeight || window.innerHeight;

  const minX = -LEFT_SAFE;
  const minY = -PAD_TOP;

  const cardsWidth = Math.max(0, contentW - RIGHT_SAFE);
  const effectiveViewportWidth = Math.max(0, vw - VIEWPORT_RIGHT_MARGIN);

  const maxX = Math.max(0, cardsWidth * ZOOM - effectiveViewportWidth);
  const maxY = Math.max(0, contentH * ZOOM - vh) + PAD_BOTTOM;

  return {
    x: Math.max(minX, Math.min(maxX, px)),
    y: Math.max(minY, Math.min(maxY, py)),
  };
}

function setTargets(px, py) {
  const c = clampPanXY(px, py);
  panX = c.x;
  panY = c.y;
  applyCSSPan();
}

let visRaf = null;
function requestVisibilityUpdate() {
  if (visRaf) return;
  visRaf = requestAnimationFrame(() => {
    visRaf = null;
    updateVisibility();
  });
}

let panRaf = null;
let pendingPanX = null;
let pendingPanY = null;
let frameCount = 0;
let isScrolling = false;
let scrollTimeout = null;

function applyCSSPan() {
  pendingPanX = panX;
  pendingPanY = panY;

  if (panRaf) return;

  if (!isScrolling) {
    isScrolling = true;
    layer.classList.add('is-scrolling');
  }
  
  clearTimeout(scrollTimeout);
  scrollTimeout = setTimeout(() => {
    isScrolling = false;
    layer.classList.remove('is-scrolling');
    requestVisibilityUpdate();
  }, 150);

  panRaf = requestAnimationFrame(() => {
    panRaf = null;
    frameCount++;
    
    const c = clampPanXY(pendingPanX, pendingPanY);
    panX = c.x;
    panY = c.y;

    layer.style.setProperty('--panx', panX + 'px');
    layer.style.setProperty('--pany', panY + 'px');
    layer.style.setProperty('--zoom', ZOOM);

    if (frameCount % 3 === 0) {
      requestVisibilityUpdate();
    }
    
    if (frameCount % 5 === 0) {
      checkAndLoadNextBatch();
    }
  });
}

function computeMinZoom() {
  const vw = stage?.clientWidth || window.innerWidth || 0;
  const vh = stage?.clientHeight || window.innerHeight || 0;
  if (!contentW || !contentH || !vw || !vh) return 0.75;

  const { RIGHT_SAFE } = getCardMetrics();
  const cardsWidth = Math.max(1, contentW - RIGHT_SAFE);

  const effectiveViewportWidth = Math.max(1, vw - VIEWPORT_RIGHT_MARGIN);
  const minWidthZoom = effectiveViewportWidth / cardsWidth;

  const isCoarsePointer = typeof window !== 'undefined' && typeof window.matchMedia === 'function'
    ? window.matchMedia('(pointer: coarse)').matches
    : false;

  const baseMin = isCoarsePointer ? 0.42 : 0.35;
  const minZoom = Math.max(minWidthZoom, baseMin);

  return Math.min(1.25, minZoom);
}

function ensureMinZoom(options = {}) {
  const { clampPan = true, syncCss = true } = options;
  const minZ = computeMinZoom();
  let adjusted = false;

  if (ZOOM < minZ) {
    ZOOM = minZ;
    adjusted = true;
  }

  if (zoomRange) {
    zoomRange.min = minZ.toFixed(2);
    if (parseFloat(zoomRange.value || ZOOM) < ZOOM) {
      zoomRange.value = ZOOM.toFixed(2);
    }
  }

  if (adjusted && clampPan) {
    const clamped = clampPanXY(panX, panY);
    panX = clamped.x;
    panY = clamped.y;
    if (syncCss) applyCSSPan();
  }

  return minZ;
}

function applyTransform() {
  applyCSSPan();
}

/* ===== PAN / ZOOM INTERATTIVI ===== */
(function enablePanZoom() {
  let dragging = false;
  let dragPointerId = null;
  let startX = 0;
  let startY = 0;
  let startPanX = 0;
  let startPanY = 0;

  const activePts = new Map();
  let pinchStart = null;

  let velocityX = 0;
  let velocityY = 0;
  let lastMoveTime = 0;
  let lastMoveX = 0;
  let lastMoveY = 0;
  let momentumRaf = null;
  const VELOCITY_DECAY = 0.96;
  const MIN_VELOCITY = 0.2;
  const VELOCITY_MULTIPLIER = 0.7;

  function dist(a, b) {
    const dx = a.x - b.x;
    const dy = a.y - b.y;
    return Math.hypot(dx, dy);
  }

  function mid(a, b) {
    return { x: (a.x + b.x) / 2, y: (a.y + b.y) / 2 };
  }

  function onPointerDown(e) {
    if (e.button !== undefined && e.button !== 0 && e.pointerType === 'mouse') return;

    if (momentumRaf) {
      cancelAnimationFrame(momentumRaf);
      momentumRaf = null;
    }
    velocityX = 0;
    velocityY = 0;

    activePts.set(e.pointerId, { x: e.clientX, y: e.clientY });

    if (activePts.size === 2) {
      const [p1, p2] = [...activePts.values()];
      pinchStart = {
        dist: dist(p1, p2),
        zoom: ZOOM,
        mid: mid(p1, p2),
      };
      dragging = false;
      stage.classList.add('dragging');
      layer.classList.add('dragging');
      return;
    }

    if (activePts.size === 1 && !pinchStart) {
      dragging = true;
      dragPointerId = e.pointerId;
      startX = e.clientX;
      startY = e.clientY;
      startPanX = panX;
      startPanY = panY;
      lastMoveTime = performance.now();
      lastMoveX = e.clientX;
      lastMoveY = e.clientY;
      try { stage.setPointerCapture(e.pointerId); } catch (err) {}
      stage.classList.add('dragging');
      layer.classList.add('dragging');
    }
  }

  function applyMomentum() {
    if (momentumRaf) cancelAnimationFrame(momentumRaf);
    
    const speed = Math.hypot(velocityX, velocityY);
    if (speed < MIN_VELOCITY) {
      velocityX = 0;
      velocityY = 0;
      momentumRaf = null;
      return;
    }

    panX += velocityX;
    panY += velocityY;
    
    const clamped = clampPanXY(panX, panY);
    
    if (clamped.x !== panX) {
      velocityX *= 0.3;
      panX = clamped.x;
    }
    if (clamped.y !== panY) {
      velocityY *= 0.3;
      panY = clamped.y;
    }
    
    applyCSSPan();

    velocityX *= VELOCITY_DECAY;
    velocityY *= VELOCITY_DECAY;

    momentumRaf = requestAnimationFrame(applyMomentum);
  }

  function onPointerMove(e) {
    const pt = activePts.get(e.pointerId);
    if (!pt) return;
    pt.x = e.clientX;
    pt.y = e.clientY;

    if (pinchStart && activePts.size === 2) {
      e.preventDefault();
      const [p1, p2] = [...activePts.values()];
      const d = dist(p1, p2);
      if (!d) return;

      const factor = d / (pinchStart.dist || d);
      const newZ = clampZoom(pinchStart.zoom * factor);
      zoomAroundPoint(newZ, pinchStart.mid.x, pinchStart.mid.y);
      return;
    }

    if (!dragging || e.pointerId !== dragPointerId) return;
    e.preventDefault();

    const now = performance.now();
    const dt = now - lastMoveTime;

    const dx = (e.clientX - startX);
    const dy = (e.clientY - startY);

    panX = startPanX - dx;
    panY = startPanY - dy;

    if (dt > 0 && dt < 100) {
      const deltaX = e.clientX - lastMoveX;
      const deltaY = e.clientY - lastMoveY;
      const newVelX = -deltaX / dt * 16 * VELOCITY_MULTIPLIER;
      const newVelY = -deltaY / dt * 16 * VELOCITY_MULTIPLIER;
      
      velocityX = velocityX * 0.3 + newVelX * 0.7;
      velocityY = velocityY * 0.3 + newVelY * 0.7;
    }

    lastMoveTime = now;
    lastMoveX = e.clientX;
    lastMoveY = e.clientY;

    applyCSSPan();
  }

  function onPointerUp(e) {
    activePts.delete(e.pointerId);

    if (pinchStart && activePts.size < 2) {
      pinchStart = null;
    }

    if (dragging && e.pointerId === dragPointerId) {
      dragging = false;
      dragPointerId = null;
      try { stage.releasePointerCapture(e.pointerId); } catch (err) {}
      stage.classList.remove('dragging');
      layer.classList.remove('dragging');

      const speed = Math.hypot(velocityX, velocityY);
      if (speed > MIN_VELOCITY) {
        applyMomentum();
      }
    }
  }

  stage.addEventListener('pointerdown', onPointerDown, { passive: false });
  stage.addEventListener('pointermove', onPointerMove, { passive: false });
  stage.addEventListener('pointerup', onPointerUp, { passive: true });
  stage.addEventListener('pointercancel', onPointerUp, { passive: true });

  if (!window.PointerEvent) {
    stage.addEventListener('touchstart', (e) => {
      if (!e.touches?.length) return;
      const t = e.touches[0];
      onPointerDown({
        pointerId: 1,
        clientX: t.clientX,
        clientY: t.clientY,
        pointerType: 'touch'
      });
    }, { passive: false });

    stage.addEventListener('touchmove', (e) => {
      if (!e.touches?.length) return;
      const t = e.touches[0];
      onPointerMove({
        pointerId: 1,
        clientX: t.clientX,
        clientY: t.clientY,
        pointerType: 'touch',
        preventDefault: () => e.preventDefault()
      });
    }, { passive: false });

    stage.addEventListener('touchend', (e) => {
      onPointerUp({ pointerId: 1 });
    }, { passive: true });
  }

  stage.addEventListener('wheel', (e) => {
    e.preventDefault();

    if (e.ctrlKey) {
      const factor = Math.exp(-e.deltaY * 0.0015);
      const newZ = clampZoom(ZOOM * factor);
      zoomAroundPoint(newZ, e.clientX, e.clientY);
      return;
    }

    panX += e.deltaX;
    panY += e.deltaY;
    applyCSSPan();
  }, { passive: false });
})();

window.addEventListener('resize', () => {
  let matchFn = () => true;

  if (currentFilter.type === 'range') {
    const { a, b } = currentFilter;
    matchFn = it => hueInRange(it.hue, a, b);
  } else if (currentFilter.type === 'neutri') {
    matchFn = it => it.hue == null;
  }

  relayoutVisible(matchFn);
  ensureMinZoom({ clampPan: true, syncCss: true });
  setTargets(panX, panY);
});


  /* === FILTRO COLORE === */
let currentFilter = { type: 'all' };
let CURRENT_FILTER_VERSION = 0; 
const ACTIVE_LABEL_FILTERS = new Set();

function hueInRange(h, a, b){
  if (h == null) return false;
  if (a <= b) return h >= a && h <= b;
  return (h >= a && h <= 359) || (h >= 0 && h <= b);
}


function applyFilter() {
  CURRENT_FILTER_VERSION++;
  const thisVersion = CURRENT_FILTER_VERSION;

  let matchFn;
  switch (currentFilter.type) {
    case 'range': {
      const { a, b } = currentFilter;
      matchFn = it => typeof it.hue === 'number' && hueInRange(it.hue, a, b);
      break;
    }
    case 'neutri':
      matchFn = it => it.hue == null;
      break;
    case 'labels': {
      const normalizedWanted = new Set(
        (currentFilter.labels || [])
          .map(normalizeColorLabel)
          .filter(Boolean)
      );
      if (!normalizedWanted.size) {
        currentFilter = { type: 'all' };
        matchFn = () => true;
      } else {
        matchFn = it => {
          const labels = it.colors || it.colorLabels || [];
          if (!labels.length) return false;
          for (const lbl of labels) {
            if (normalizedWanted.has(normalizeColorLabel(lbl))) return true;
          }
          return false;
        };
      }
      break;
    }
    case 'all':
    default:
      matchFn = () => true;
  }

  swapWithFade(() => {
    relayoutVisible(matchFn);
