  </span>
  <span class="gel-toggle-label">Filtri</span>
</button>
  </div>
</div>
<section class="gel-exp" id="gel-experience">
  

  <div class="gel-overlay" id="gel-filters-overlay" hidden></div>

<aside class="gel-filter-drawer" id="gel-filter-drawer" aria-hidden="true" aria-labelledby="gel-filter-title">
  <header class="gel-filter-header">
    <h2 id="gel-filter-title" style="opacity:0">Filtri</h2>
    <h2 id="gel-filter-title">COLORE</h2>
    <button type="button" class="gel-filter-close" id="gel-filter-close" aria-label="Chiudi">✕</button>
  </header>

  <div class="gel-filter-body" id="gel-filter-body">
  <div class="gel-hue-rail">
</div>
  </div>

  <button class="gel-scrollmore" style="border:none; width:100%; border-radius:0px; " aria-label="Scorri giù">
    <span class="gel-chevron"></span>
  </button>
</aside>



  <!-- Toolbar -->
  <div class="gel-toolbar" id="gel-toolbar" style="display:none" aria-label="Strumenti visualizzazione">
    <div class="gel-zoom">
      <button class="gel-btn" id="zoom-minus" aria-label="Riduci zoom">−</button>
      <input type="range" id="zoom-range" min="0.45" max="1.25" step="0.01" value="0.90" aria-label="Zoom">
      <button class="gel-btn" id="zoom-plus" aria-label="Aumenta zoom">+</button>
    </div>

    <div class="gel-color-nav">
      
      <input type="range" id="hue-range" min="0" max="359" step="1" value="0" aria-label="Selettore tonalità">
      <button class="gel-btn" id="goto-hue" style="display:none">Vai</button>
      <br>
      <div class="gel-chips">
        <button class="chip" data-label="Bordeaux" data-chip-id="bordeaux">Bordeaux</button>
        <button class="chip" data-label="Rosso" data-chip-id="rosso">Rosso</button>
        <button class="chip" data-label="Fucsia" data-chip-id="fucsia">Fucsia</button>
        <button class="chip" data-label="Rosa" data-chip-id="rosa">Rosa</button>
        <button class="chip" data-label="Viola" data-chip-id="viola">Viola</button>
        <button class="chip" data-label="Blu" data-chip-id="blu">Blu</button>
        <button class="chip" data-label="Azzurro" data-chip-id="azzurro">Azzurro</button>
        <button class="chip" data-label="Verde" data-chip-id="verde">Verde</button>
        <button class="chip" data-label="Giallo" data-chip-id="giallo">Giallo</button>
        <button class="chip" data-label="Arancione" data-chip-id="arancione">Arancione</button>
        <button class="chip" data-label="Marrone" data-chip-id="marrone">Marrone</button>
        <button class="chip" data-label="Nude" data-chip-id="nude">Nude</button>
        <button class="chip" data-label="Bianco" data-chip-id="bianco">Bianco</button>
        <button class="chip" data-label="Nero" data-chip-id="nero">Nero</button>
        <button class="chip" data-label="Grigio" data-chip-id="grigio">Grigio</button>
        <button class="chip" data-label="Argento" data-chip-id="argento">Argento</button>
        <button class="chip" data-label="Oro" data-chip-id="oro">Oro</button>
        <button class="gel-btn" id="gel-reset" aria-label="Azzera filtri">Azzera filtri</button>
        <br>
      </div>
      
    </div>
  </div>
  {% if collection and collection.metafields.custom.presentation != blank %}
    <div class="gel-exp__intro">{{ collection.metafields.custom.presentation }}</div>
  {% endif %}

  <!-- Stage + Layer -->
  <div class="gel-stage"  id="gel-stage" aria-live="polite">
  <div class="gel-exp__loader" id="gel-exp-loader">
    <div class="gel-loader-box">
      <div class="gel-spinner" aria-label="Caricamento…"></div>
      <p class="gel-loader-text">Caricamento colori… <span class="gel-inline-spinner" aria-hidden="true"></span></p>
    </div>
  </div>

  <div class="gel-layer" id="gel-layer" style="margin-top:25px;"></div>
  
  <div class="gel-loading-indicator" id="gel-loading-indicator">Caricamento prodotti...</div>
</div>

<template id="gel-card-template">
  <article class="gel-card">
    <figure class="gel-media">
      <img loading="lazy" decoding="async" draggable="false">
      <div class="gel-top">
        <span class="gel-code"></span>
        <button class="gel-icon-btn gel-fav" style="display:none" aria-label="Preferiti">♥</button>
        <div class="th_wl_col_btn gel-icon-btn"></div>
      </div>
      <div class="gel-bottom">
        <span class="gel-price"></span>
        <button class="gel-icon-btn gel-add" aria-label="Carrello">
          <svg viewBox="0 0 16 15" aria-hidden="true" class="gel-cart" width="16" height="15" fill="none">
            <path d="M10.6716 3.00182L13.3482 3.00343C13.6926 3.0473 13.9865 3.30389 14.0752 3.65167C14.4354 6.78747 14.7494 9.93084 15.0961 13.0692C15.1389 13.5578 14.7871 13.9924 14.3149 14.0287H0.873367C0.406277 13.9843 0.0609506 13.5545 0.103091 13.0692L1.1027 3.75573C1.15792 3.35626 1.47464 3.04638 1.861 3.00205H4.5278C4.61629 1.97776 5.19184 1.05088 6.04373 0.534715C6.99809 -0.0432395 8.19265 -0.0448476 9.14857 0.530351C10.0042 1.04536 10.5829 1.97501 10.6716 3.00159V3.00182ZM10.0947 3.00182C9.94812 1.60471 8.7784 0.6181 7.42726 0.692757C6.24467 0.757995 5.2098 1.78044 5.10445 3.00182H10.0947ZM1.90802 3.59057C1.79801 3.61423 1.70774 3.68245 1.67425 3.79639L0.669764 13.1826C0.689281 13.3333 0.803503 13.439 0.950771 13.4427H14.248C14.4203 13.4353 14.5347 13.3055 14.5303 13.1266C14.1832 10.0096 13.8734 6.88624 13.5154 3.77158C13.4755 3.65948 13.3617 3.59218 13.2499 3.58712L1.90779 3.59057H1.90802Z" fill="currentColor"/>
          </svg>
        </button>
      </div>
    </figure>
  </article>
</template>

  <noscript>
    <div class="gel-exp__fallback">
      <h2>I nostri gel</h2>
      {% assign h = section.settings.collection_handle | default: 'smalto-semipermanente' %}
      {% for p in collections[h].products limit: 24 %}
        <a href="{{ p.url }}" class="gel-fb__item">
          <img src="{{ p.featured_image | image_url: width: 180 }}" alt="{{ p.title | escape }}">
          <span>{{ p.title }}</span>
        </a>
      {% endfor %}
      <p>Attiva JavaScript per l'esperienza completa.</p>
    </div>
  </noscript>

  <!-- ===== LONG PRESS PREVIEW POPUP ===== -->
  <div class="gel-preview-backdrop" id="gel-preview-backdrop"></div>
  <div class="gel-preview-card" id="gel-preview-card" role="dialog" aria-modal="true" aria-label="Anteprima prodotto">
    <div class="gel-preview-header">
      <img class="gel-preview-thumb" id="gel-preview-thumb" src="" alt="">
      <div class="gel-preview-meta">
        <div class="gel-preview-title" id="gel-preview-title"></div>
        <div class="gel-preview-price" id="gel-preview-price"></div>
        <div class="gel-preview-badge"><b>HEMA Free &amp; TPO Free</b></div>
      </div>
      <button class="gel-preview-close" id="gel-preview-close" aria-label="Chiudi anteprima">✕</button>
    </div>
    <div class="gel-preview-body">
      <p class="gel-preview-desc" id="gel-preview-desc"></p>
    </div>
    <a class="gel-preview-cta" id="gel-preview-cta" href="#">Visualizza tutti i dettagli</a>
  </div>

</section>

{% schema %}
{
  "name": "GSAP – Gel Experience",
  "settings": [
    { "type": "text",  "id": "collection_handle", "label": "Handle collezione", "default": "smalto-semipermanente" },
    { "type": "range", "id": "image_width", "label": "Larghezza immagine (px)", "min": 160, "max": 900, "step": 10, "default": 260 },
    { "type": "range", "id": "grid_gap", "label": "Spazio tra card (px)", "min": 20, "max": 20, "step": 5, "default": 20 },
    { "type": "text",  "id": "sf_token", "label": "Storefront API token (public)", "default": "7ca1a0b104dd941c0417df269d4f0295" }
  ]
}
{% endschema %}

<style>

  @media (max-width: 768px) {
  .color-lab-box {
    top: 100px !important;
  }
}

  #gel-layer {
    margin-top: 100px !important;
    
  }
@media (min-width: 1999px) { 
  

.gel-filter-drawer {
    top: 20vh;
}

}
  .gel-icon-btn.gel-add.is-active{
  background: var(--cfy-green);
  color: #fff;
  border-color: var(--cfy-green);
}
.gel-icon-btn.gel-add svg{
  fill:var(--cfy-green);
}
.gel-icon-btn.gel-add..is-active svg{
  fill:white;
}

.gel-icon-btn.gel-add.is-active svg path{ fill:#fff; }

.gel-icon-btn.gel-add svg {
  fill: currentColor;
}

.gel-icon-btn.gel-add svg path {
  fill: currentColor;
}

.gel-icon-btn.gel-add.is-loading{
  pointer-events: none;
  opacity: .65;
  position: relative;
}
.gel-icon-btn.gel-add.is-loading::after{
  content: "";
  position: absolute; inset: 0;
  margin: auto;
  width: 14px; height: 14px;
  border-radius: 50%;
  border: 2px solid rgba(0,100,80,.25);
  border-top-color: var(--cfy-green);
  animation: gel-spin .6s linear infinite;
}


  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;500&display=swap');

.color-lab-box {
  background: #f5f3eb;
  display: flex;
  position: fixed;
  left: 0;
  right: 0;
  z-index: 29;
  align-items: center;
  justify-content: space-between;
  padding: 14px 16px;
  width: 100%;
  margin: 0 auto;
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
  /* top viene impostato via JS in base all'altezza dell'header */
  top: 0;
}

.color-lab-box .title {
  font-family: "Romie Trial", "Times New Roman", serif;
  font-size: 28px;
  line-height: 1.1;
  color: #006450;
  margin: 0 0 4px 0;
}

.color-lab-box .subtitle {
  font-family: "Poppins", system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  font-size: 13px;
  letter-spacing: 0.02em;
  color: #006450;
  margin: 0;
  font-weight: 400;
  text-transform: none;
}

.color-lab-box .subtitle.italic {
  font-style: italic;
  font-weight: 600;
}


  :root{
    --cfy-green:#006450; --cfy-btn-bg:#f9f8f2;
  }
.gel-filter-drawer .gel-btn, .gel-filter-drawer .chip{ padding:10px 14px; height:35px !important; }
.gel-filter-drawer input[type="range"]{ width:100%; }
  .gel-filter-drawer{
  position: fixed; top:0; right:0; height:100vh;
  width: 230px !important;    max-width: 92vw;
  background:#fff;
  transform: translateX(100%); transition: transform .28s ease;
  z-index: 99999; display:flex; flex-direction:column;
  border-left: 1px solid #e9ecef;
}
.gel-filter-drawer.is-open{ transform: translateX(0); }


  .gel-exp{ --zoom:1; --panx:0px; --pany:0px; }
  .gel-exp__intro{max-width:920px;margin:10px auto 18px;text-align:center}

  .gel-toggle-wrap{  inset:16.5% 20% auto  auto; z-index: 10; }

.gel-overlay{
  position: fixed; inset:0; background: rgba(0,0,0,.36);
  opacity:0; pointer-events:none; transition: opacity .24s ease; z-index: 1000;
}
.gel-overlay.is-on{ opacity:1; pointer-events:auto; }

.gel-filter-header{
  display:flex; align-items:center; justify-content:space-between;
  padding:14px 16px;
}
.gel-filter-header h2{ margin:0; font-size:18px; color:var(--cfy-green); }
.gel-filter-close{
  padding: 0px;
  background:transparent;  color:var(--cfy-green);
  border:none !important;
  border-radius:999px; width:34px; height:34px; line-height:1; cursor:pointer;
}


.footer{
  display:none !important
}
.shopify-section-group-footer-group {
  display:none !important
}
.gel-filter-body{ overflow:hidden !important; }

.gel-filter-drawer .gel-toolbar{
  display:block; max-width:none; margin:0; padding:0; overflow:auto !important;
}
.gel-filter-drawer .gel-color-nav{ display:flex; flex-direction:column; align-items:stretch;  }
.gel-filter-drawer .gel-chips{ justify-content:flex-start;    display: flex; flex-direction: column; }

@media (max-width: 768px){
  .gel-filter-drawer{ width: 320px; max-width: 50vw;}
  .gel-toggle-wrap{ top: 135px;
left: 70%; }
}

#gel-layer{ padding:0 !important; }
.th_wl_col_btn.gel-icon-btn:has(.th_wl_button_after) {
  background: #006450 !important;
}
.th_wl_col_btn .th_wl_button_after svg, .th_wl_col_btn .th_wl_button_after svg path{
  fill:white !important
}


.gel-stage{ height: calc(100vh - 24px); }
  .gel-toolbar{
    display:flex; gap:20px; align-items:center; justify-content:center; flex-wrap:wrap;
    margin:6px auto 10px; transition:max-height .28s ease, opacity .28s ease; overflow:hidden;
    padding:0 18px;
    max-width:1200px;
  }
  .gel-toolbar.is-hidden{ max-height:0; opacity:0; margin:0; pointer-events:none; }
.gel-zoom{ display:none !important; }
  .gel-color-nav{display:flex;align-items:center;flex-wrap:wrap}
  .gel-label{font-weight:600}

  .gel-btn,.chip{
    background:var(--cfy-btn-bg);
    border:1px solid var(--cfy-green);
    color:var(--cfy-green);
    border-radius:50px;
    padding:8px 14px;
    cursor:pointer;
    line-height:1;
  }
  .gel-btn:hover,.chip:hover{ filter:brightness(.97); }

  #zoom-range{ width:210px; accent-color:var(--cfy-green); outline:none; }
  #zoom-range::-webkit-slider-runnable-track{ height:8px; border-radius:999px; background:#e6f0ee; border:1px solid #d9e6e2; }
  #zoom-range::-webkit-slider-thumb{ margin-top:-6px; width:18px; height:18px; border-radius:50%; background:var(--cfy-green); border:2px solid var(--cfy-green); }
  #zoom-range::-moz-range-track{ height:8px; border-radius:999px; background:#e6f0ee; border:1px solid #d9e6e2; }
  #zoom-range::-moz-range-thumb{ width:9px; height:9px; border-radius:50%; background:var(--cfy-green); border:2px solid var(--cfy-green); }

  .gel-chips{display:flex;gap:8px;flex-wrap:wrap}
  
  .gel-loading-indicator {
    position: fixed;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    background: rgba(0, 100, 80, 0.9);
    color: white;
    padding: 8px 16px;
    border-radius: 20px;
    font-size: 14px;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
    z-index: 1000;
  }
  .gel-loading-indicator.visible {
    opacity: 1;
  }

  .gel-stage{ 
    position:relative; 
    height:calc(100vh - 120px); 
    overflow:hidden; 
    transform: translateZ(0);
    -webkit-transform: translateZ(0);
  }
  .gel-stage, .gel-layer{ 
    cursor:grab; 
    touch-action: none; 
    -ms-touch-action: none;
    -webkit-overflow-scrolling: touch;
  }
  .gel-stage.dragging, .gel-layer.dragging{ cursor:grabbing; }

.gel-layer{
  position:absolute; top:0; left:0;
  transform: translate3d(calc(var(--panx) * -1), calc(var(--pany) * -1), 0) scale(var(--zoom, 1));
  transform-origin:0 0;
  will-change: transform;
  opacity:0; transition:opacity .25s ease;
  backface-visibility: hidden;
  -webkit-backface-visibility: hidden;
  -webkit-transform: translate3d(calc(var(--panx) * -1), calc(var(--pany) * -1), 0) scale(var(--zoom, 1));
  perspective: 1000px;
  -webkit-perspective: 1000px;
}

    .gel-stage.ready .gel-layer{ opacity:1; }
 .gel-layer.is-swapping{ opacity:0; transition: opacity .14s ease; }
 .gel-card{
  position:absolute; width: calc(var(--imgw, 260px) - 40px); 
  border-radius:16px; 
  overflow:hidden;
  filter: drop-shadow(0 6px 18px rgba(0,0,0,.08));
  user-select:none; 
  backface-visibility:hidden;
  -webkit-backface-visibility:hidden;
  opacity:0; 
  transform: translate3d(var(--x,0), var(--y,0), 0) scale(1);
  -webkit-transform: translate3d(var(--x,0), var(--y,0), 0) scale(1);
  transition: none !important;
  will-change: transform, opacity;
  content-visibility: auto;
  background: transparent;
}
.gel-card.on{ opacity:1; }

.gel-card figure,
.gel-card .gel-media {
  margin: 0;
  padding: 0;
  display: block;
  background: transparent;
}

.gel-layer.is-scrolling .gel-card {
  filter: none;
}

.gel-layer.is-scrolling {
  pointer-events: none;
}

.gel-layer.is-scrolling .gel-card img {
  image-rendering: auto;
}

.gel-card img[src*="data:image"] {
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
}

@keyframes shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}

.gel-card img {
  width: calc(100% + 40px);
  height: calc(var(--imgw) * 1.10);
  object-fit: cover;
  display: block;
  border-radius: 16px;
  transform: translateZ(0);
  -webkit-transform: translateZ(0);
  image-rendering: -webkit-optimize-contrast;
  image-rendering: crisp-edges;
}
.gel-media {
  background: linear-gradient(90deg, #edebe2 25%, #e3e1d9 50%, #edebe2 75%);
  background-size: 200% 100%;
  animation: shimmer 1.4s ease-in-out infinite;
  border-radius: 16px;
}
.gel-media.img-loaded {
  background: none;
  animation: none;
}
.gel-card img {
  opacity: 0;
  transition: opacity 0.5s ease;
}
.gel-card img.img-loaded {
  opacity: 1;
}


.gel-card .gel-media {
  position: relative;
  width: 100%;
  overflow: visible;
}
.gel-top, .gel-bottom{
  position:absolute;  left: 6px;
