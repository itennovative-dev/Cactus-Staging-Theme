  const renderedItems = PRODUCT_LIST.length;
  const renderedRows = Math.ceil(renderedItems / cols);
  const renderedHeight = renderedRows * (CARD_H + GAP_Y);
  
  const threshold = renderedHeight * 0.6;
  
  if (currentScrollY + viewportHeight > threshold) {
    loadNextBatch();
  }
}

