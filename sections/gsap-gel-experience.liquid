async function addToCart(merchId, sourceBtn){
  const toIdle = () => setAddBtnState(sourceBtn, 'idle');
  try{
    const variantId = variantIdForAjax(merchId);
    if (!variantId) throw new Error('ID variante non valido');

    const isActive = !!(sourceBtn && sourceBtn.classList.contains('is-active'));

    setAddBtnState(sourceBtn, 'loading');

    const ROOT = (window.Shopify && Shopify.routes && Shopify.routes.root) || '/';
    const addUrl    = ROOT + 'cart/add.js';
    const changeUrl = ROOT + 'cart/change.js';
    const cartUrl   = ROOT + 'cart.js';

    let cart;

    if (isActive) {
      let res = await fetch(changeUrl, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Accept': 'application/json'
        },
        body: JSON.stringify({ id: variantId, quantity: 0 }),
        credentials: 'include'
      });
      if (!res.ok){
        let err; try { err = await res.json(); } catch {}
        throw new Error(err?.description || 'Errore nella rimozione dal carrello');
      }
      try { cart = await res.json(); } catch { cart = null; }
      if (!cart || typeof cart.item_count !== 'number'){
        cart = await fetch(cartUrl, { credentials:'include', headers:{ 'Accept':'application/json' } }).then(r => r.json());
      }

      setAddBtnState(sourceBtn, 'idle');
      syncAddButtonsWithCart(cart);
      await refreshCartUI(cart);
      document.dispatchEvent(new CustomEvent('cfy:cart-removed', {
        detail: { variantId, cart }
      }));
      return;
    }

    const fd = new FormData();
    fd.append('id', variantId);
    fd.append('quantity', '1');

    let res = await fetch(addUrl, {
      method: 'POST',
      headers: { 'Accept': 'application/json' },
      body: fd,
      credentials: 'include'
    });
    if (!res.ok){
      let err; try { err = await res.json(); } catch {}
      throw new Error(err?.description || 'Errore nell\'aggiunta al carrello');
    }

    cart = await fetch(cartUrl, { credentials:'include', headers:{ 'Accept':'application/json' } }).then(r => r.json());

    if (!cart || typeof cart.item_count !== 'number' || cart.item_count === 0){
      await postViaHiddenForm(variantId, 1);
      cart = await fetch(cartUrl, { credentials:'include', headers:{ 'Accept':'application/json' } }).then(r => r.json());
    }

    setAddBtnState(sourceBtn, 'active');

    syncAddButtonsWithCart(cart);

    await refreshCartUI(cart);

    document.dispatchEvent(new CustomEvent('cfy:cart-added', {
      detail: { variantId, cart }
    }));

  }catch(err){
    console.error(err);
    alert(err.message || 'Impossibile aggiungere al carrello.');
    toIdle();
  }finally{
    if (sourceBtn) sourceBtn.classList.remove('is-loading');
  }
}



function showToast(msg){
  let t = document.getElementById('gel-toast');
  if (!t){
    t = document.createElement('div');
    t.id = 'gel-toast';
    t.setAttribute('role','status');
    t.setAttribute('aria-live','polite');

    Object.assign(t.style, {
      position:'fixed',
      left:'50%', top:'50%',
      transform:'translate(-50%, -50%)',
      zIndex: 9999,
      background:'#fff',
      color:'var(--cfy-green)',
      border:'1px solid var(--cfy-green)',
      borderRadius:'16px',
      boxShadow:'0 12px 28px rgba(0,0,0,.14)',
      padding:'16px 18px 18px',
      minWidth:'260px',
      maxWidth:'90vw',
      display:'grid',
      gap:'12px',
      placeItems:'center',
      opacity:0,
      transition:'opacity .2s ease'
    });

    const msgEl = document.createElement('div');
    msgEl.className = 'toast-msg';
    msgEl.style.fontWeight = '700';

    const actions = document.createElement('div');
    actions.className = 'toast-actions';
    Object.assign(actions.style, { display:'flex', gap:'10px' });

    const goBtn = document.createElement('button');
    goBtn.type = 'button';
    goBtn.textContent = 'Vai al carrello';
    Object.assign(goBtn.style, {
      background:'var(--cfy-green)',
      color:'#fff',
      border:'1px solid var(--cfy-green)',
      borderRadius:'999px',
      padding:'8px 14px',
      cursor:'pointer',
      fontWeight:'600'
    });
    goBtn.addEventListener('click', async (ev) => {
      ev.preventDefault();
      hide();
      await refreshAndOpenCart();
    });

    const closeBtn = document.createElement('button');
    closeBtn.type = 'button';
    closeBtn.textContent = '×';
    Object.assign(closeBtn.style, {
      position:'absolute',
      top:'-10px', right:'-10px',
      background:'transparent',
      border:'none',
      color:'var(--cfy-green)',
      fontSize:'20px',
      lineHeight:'1',
      cursor:'pointer'
    });
    closeBtn.addEventListener('click', hide);

    actions.appendChild(goBtn);
    t.append(msgEl, actions, closeBtn);
    document.body.appendChild(t);

    function hide(){
      t.style.opacity = 0;
      t.style.pointerEvents = 'none';
      clearTimeout(t._hidet);
    }
    t.hide = hide;

    t.addEventListener('mouseenter', () => clearTimeout(t._hidet));
    t.addEventListener('focusin', () => clearTimeout(t._hidet));
    t.addEventListener('mouseleave', () => { t._hidet = setTimeout(t.hide, 2600); });
    t.addEventListener('focusout', () => { t._hidet = setTimeout(t.hide, 2600); });
  }

  t.querySelector('.toast-msg').textContent = msg;
  t.style.opacity = 1;
  t.style.pointerEvents = 'auto';
  clearTimeout(t._hidet);
  t._hidet = setTimeout(t.hide, 2600);
}

