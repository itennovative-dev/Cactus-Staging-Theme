function findColorLabelByHue(h) {
  if (!COLOR_LABEL_PALETTE.length) return null;

  for (const entry of COLOR_LABEL_PALETTE) {
    const { a, b } = entry;
    const inRange = (a <= b)
      ? (h >= a && h <= b)
      : (h >= a || h <= b);
    if (inRange) return entry;
  }

  let best = null;
  let bestDist = Infinity;
  for (const entry of COLOR_LABEL_PALETTE) {
    let d = Math.abs(entry.mid - h);
    d = Math.min(d, 360 - d);
    if (d < bestDist) {
      bestDist = d;
      best = entry;
    } else if (d === bestDist && best && entry.span < best.span) {
      best = entry;
    }
  }
  return best;
}
function applyColorLabelFilter(label, fromHue = false) {
  if (!label) return;

  if (fromHue) {
    setLabelFilters([label]);
  } else {
    toggleLabelFilter(label);
  }
}


function buildDynamicLabelRanges(products) {
  const bucket = new Map();

  products.forEach(p => {
    const labels = p.colors || p.colorLabels || [];
    const h = p.hue;
    labels.forEach(label => {
      if (!label) return;
      if (!bucket.has(label)) bucket.set(label, []);
      if (typeof h === 'number') {
        bucket.get(label).push(h);
      }
    });
  });

  const result = {};

  bucket.forEach((hues, label) => {
    if (!hues.length) return;

    hues.sort((a,b) => a - b);

    const min = hues[0];
    const max = hues[hues.length - 1];
    const spread = max - min;

    if (spread <= 80) {
      const pad = 6;
      result[label] = {
        type: "range",
        a: Math.max(0, min - pad),
        b: Math.min(359, max + pad),
      };
      return;
    }

    let bestGap = -1;
    let bestIndex = -1;
    for (let i = 0; i < hues.length - 1; i++) {
      const gap = hues[i+1] - hues[i];
      if (gap > bestGap) {
        bestGap = gap;
        bestIndex = i;
      }
    }

    const start = hues[bestIndex + 1];
    const rotated = hues.map(h => (h - start + 360) % 360).sort((a,b) => a - b);

    const rMin = rotated[0];
    const rMax = rotated[rotated.length - 1];
    const rSpread = rMax - rMin;

    if (rSpread <= 80) {
      const pad = 6;
      let a = (rMin - pad + start + 360) % 360;
      let b = (rMax + pad + start) % 360;
      result[label] = { type: "range", a, b };
      return;
    }
  });

  return result;
}

function buildDynamicColorChips(products, labelRanges) {
  const wrap = document.querySelector('.gel-chips');
  if (!wrap) return;

  wrap.innerHTML = '';

  const allBtn = document.createElement('button');
  allBtn.className = 'chip';
  allBtn.textContent = 'Tutti i colori';
  allBtn.dataset.all = '1';
  wrap.appendChild(allBtn);

  const labelsSet = new Set();
  products.forEach(p => {
    const labels = p.colors || p.colorLabels || [];
    labels.forEach(l => {
      if (!l) return;
      labelsSet.add(l);
    });
  });

  [...labelsSet].sort().forEach(label => {
    const btn = document.createElement('button');
    btn.className = 'chip';
    btn.textContent = label;

    const rangeDef = labelRanges && labelRanges[label];

    if (rangeDef && rangeDef.type === 'range') {
      btn.dataset.rangeA = rangeDef.a;
      btn.dataset.rangeB = rangeDef.b;
    } else {
      btn.dataset.label = label;
    }

    wrap.appendChild(btn);
  });

  wrap.querySelectorAll('.chip').forEach(bindLabelChip);
}

