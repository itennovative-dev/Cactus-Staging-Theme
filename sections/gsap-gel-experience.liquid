  function normalizeColorLabel(str) {
  if (!str) return null;
  let s = String(str).trim();

  s = s.replace(/\s+/g, ' ').trim();

  return s.charAt(0).toUpperCase() + s.slice(1);
}

function parseColorValueToArray(val) {
  if (!val) return [];

  if (Array.isArray(val)) {
    return val
      .map(normalizeColorLabel)
      .filter(Boolean);
  }

  let s = String(val).trim();

  if (s.startsWith('[') && s.endsWith(']')) {
    try {
      const arr = JSON.parse(s);
      if (Array.isArray(arr)) {
        return arr.map(normalizeColorLabel).filter(Boolean);
      }
    } catch (e) {}
  }

  const single = normalizeColorLabel(s);
  return single ? [single] : [];
}
function clampZoom(z){
  const minZ = computeMinZoom();
  return Math.max(minZ, Math.min(1.25, z));
}

function zoomAroundPoint(newZoom, clientX, clientY){
  const rect = stage.getBoundingClientRect();
  const sx = clientX - rect.left;
  const sy = clientY - rect.top;

  const wx = (panX + sx) / ZOOM;
  const wy = (panY + sy) / ZOOM;

  ZOOM = newZoom;
  const nx = wx * ZOOM - sx;
  const ny = wy * ZOOM - sy;

  setTargets(nx, ny);
  panX = nx; panY = ny;
  const minZ = computeMinZoom();
  if (zoomRange) {
    zoomRange.min = minZ.toFixed(2);
    zoomRange.value = ZOOM.toFixed(2);
  }
  applyCSSPan();
}


