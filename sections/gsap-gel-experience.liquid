function loadNextBatch() {
  if (isLoadingBatch) return;
  if (currentBatch >= totalBatches - 1) return;
  
  isLoadingBatch = true;
  
  const indicator = document.getElementById('gel-loading-indicator');
  if (indicator) indicator.classList.add('visible');
  
  currentBatch++;
  
  const start = currentBatch * BATCH_SIZE;
  const end = Math.min(start + BATCH_SIZE, allItemsToRender.length);
  const nextBatch = allItemsToRender.slice(start, end);
  
  requestAnimationFrame(() => {
    placeAsGrid(nextBatch, true);
    updateVisibility();
    isLoadingBatch = false;
    
    setTimeout(() => {
      if (indicator) indicator.classList.remove('visible');
    }, 500);
  });
}

