  function placeAsGrid(items, append = false){
const startTime = performance.now();

const { W, CARD_W, CARD_H, RIGHT_SAFE } = getCardMetrics();
const { GAP_X, GAP_Y } = getGaps();

const cols = getCols();

const totalItems = allItemsToRender.length || items.length;
const rows = Math.ceil(totalItems / cols);

contentW = cols * CARD_W + (cols - 1) * GAP_X + RIGHT_SAFE;
contentH = rows * CARD_H + (rows - 1) * GAP_Y;
layer.style.width  = Math.ceil(contentW) + 'px';
layer.style.height = Math.ceil(contentH) + 'px';

const startIndex = append ? PRODUCT_LIST.length : 0;

const fragment = document.createDocumentFragment();

items.forEach((it, idx) => {
  const i = startIndex + idx;
  const col = i % cols;
  const row = (i - col) / cols;

  const x = col * (CARD_W + GAP_X);
  const y = row * (CARD_H + GAP_Y);

  it.x = x; it.y = y;

  if (USE_OPTIMIZED_RENDERING) {
    const card = createOptimizedCard(it, x, y, W);
    fragment.appendChild(card);
    return;
  }
});
  
  if (fragment.hasChildNodes()) {
    layer.appendChild(fragment);
  }
  
  if (append) {
    PRODUCT_LIST.push(...items);
  } else {
    PRODUCT_LIST = [...items];
  }
  
  if (!append) {
    setTimeout(() => initWishlistClub(), 1000);
  }
  
  const endTime = performance.now();
  console.log(`⚡ Rendering ${items.length} card in ${(endTime - startTime).toFixed(2)}ms`);
}

