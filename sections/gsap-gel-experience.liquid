function extractChipLabel(chip){
  if (!chip) return '';
  return chip.dataset.label || chip.dataset.color || chip.textContent || '';
}

const ACTIVE_CHIP_IDS = new Set();

const STORAGE_KEY_CHIP_IDS = 'gel_active_chip_ids';
const STORAGE_KEY_LABEL_FILTERS = 'gel_active_label_filters';

function saveFiltersToSession() {
  try {
    sessionStorage.setItem(STORAGE_KEY_CHIP_IDS, JSON.stringify(Array.from(ACTIVE_CHIP_IDS)));
    sessionStorage.setItem(STORAGE_KEY_LABEL_FILTERS, JSON.stringify(Array.from(ACTIVE_LABEL_FILTERS)));
  } catch (e) {
    console.warn('Errore salvataggio filtri:', e);
  }
}

function loadFiltersFromSession() {
  try {
    const savedChipIds = sessionStorage.getItem(STORAGE_KEY_CHIP_IDS);
    const savedLabelFilters = sessionStorage.getItem(STORAGE_KEY_LABEL_FILTERS);
    
    if (savedChipIds) {
      const chipIds = JSON.parse(savedChipIds);
      chipIds.forEach(id => ACTIVE_CHIP_IDS.add(id));
    }
    
    if (savedLabelFilters) {
      const labelFilters = JSON.parse(savedLabelFilters);
      labelFilters.forEach(label => ACTIVE_LABEL_FILTERS.add(label));
    }
    
    return ACTIVE_CHIP_IDS.size > 0 || ACTIVE_LABEL_FILTERS.size > 0;
  } catch (e) {
    console.warn('Errore caricamento filtri:', e);
    return false;
  }
}

function clearFiltersFromSession() {
  try {
    sessionStorage.removeItem(STORAGE_KEY_CHIP_IDS);
    sessionStorage.removeItem(STORAGE_KEY_LABEL_FILTERS);
  } catch (e) {}
}

function syncLabelChipsUI(){
  document.querySelectorAll('.chip').forEach(chip => {
    const chipId = chip.dataset.chipId;
    
    if (chipId) {
      if (ACTIVE_CHIP_IDS.has(chipId)) {
        chip.classList.add('is-active');
      } else {
        chip.classList.remove('is-active');
      }
    } else {
      const normalized = normalizeColorLabel(extractChipLabel(chip));
      if (!normalized) return;
      
      if (ACTIVE_LABEL_FILTERS.has(normalized)) {
        chip.classList.add('is-active');
      } else {
        chip.classList.remove('is-active');
      }
    }
  });
}

function applyActiveLabelFilters(){
  if (ACTIVE_LABEL_FILTERS.size) {
    currentFilter = { type: 'labels', labels: Array.from(ACTIVE_LABEL_FILTERS) };
  } else if (currentFilter.type === 'labels') {
    currentFilter = { type: 'all' };
  }
  
  saveFiltersToSession();
  
  applyFilter();
  syncLabelChipsUI();
  gotoHue?.classList.remove('is-active');
}

function setLabelFilters(labels = []){
  ACTIVE_LABEL_FILTERS.clear();
  labels.forEach(label => {
    const normalized = normalizeColorLabel(label);
    if (normalized) ACTIVE_LABEL_FILTERS.add(normalized);
  });
  applyActiveLabelFilters();
}

function toggleLabelFilter(label, options = {}){
  const normalized = normalizeColorLabel(label);
  if (!normalized) return;
  
  const clickedChip = options.clickedChip;
  const chipId = clickedChip ? clickedChip.dataset.chipId : null;

  if (options.exclusive) {
    setLabelFilters([normalized]);
    return;
  }

  if (chipId) {
    if (ACTIVE_CHIP_IDS.has(chipId)) {
      ACTIVE_CHIP_IDS.delete(chipId);
      
      const otherChipsWithSameLabel = Array.from(document.querySelectorAll('.chip'))
        .filter(c => {
          const cId = c.dataset.chipId;
          const cLabel = normalizeColorLabel(extractChipLabel(c));
          return cId && ACTIVE_CHIP_IDS.has(cId) && cLabel === normalized;
        });
      
      if (otherChipsWithSameLabel.length === 0) {
        ACTIVE_LABEL_FILTERS.delete(normalized);
      }
    } else {
      ACTIVE_CHIP_IDS.add(chipId);
      ACTIVE_LABEL_FILTERS.add(normalized);
    }
  } else {
    if (ACTIVE_LABEL_FILTERS.has(normalized)) {
      ACTIVE_LABEL_FILTERS.delete(normalized);
    } else {
      ACTIVE_LABEL_FILTERS.add(normalized);
    }
  }
  
  applyActiveLabelFilters();
}

function clearLabelFilters({ silent = false } = {}){
  if (!ACTIVE_LABEL_FILTERS.size && currentFilter.type !== 'labels') {
    if (!silent) syncLabelChipsUI();
    return;
  }
  ACTIVE_LABEL_FILTERS.clear();
  ACTIVE_CHIP_IDS.clear();
  clearFiltersFromSession();
  if (silent) {
    if (currentFilter.type === 'labels') currentFilter = { type: 'all' };
    syncLabelChipsUI();
  } else {
    applyActiveLabelFilters();
  }
}

function handleLabelChipClick(chip){
  if (!chip) return;

  const isAll = chip.dataset.all === '1';
  const rangeAttr = chip.dataset.range;
  const rangeA = chip.dataset.rangeA;
  const rangeB = chip.dataset.rangeB;
  const label = extractChipLabel(chip);

  if (isAll) {
    clearFilter();
    deactivateAllFiltersUI();
    return;
  }

  if (rangeAttr) {
    clearLabelFilters({ silent: true });
    if (rangeAttr === 'null') {
      setFilterNeutri();
    } else {
      const [a, b] = rangeAttr.split(',').map(Number);
      setFilterRange(a, b);
    }
    return;
  }

  if (rangeA !== undefined && rangeB !== undefined) {
    clearLabelFilters({ silent: true });
    setFilterRange(Number(rangeA), Number(rangeB));
    return;
  }

  if (label) {
    toggleLabelFilter(label, { clickedChip: chip });
  }
}

function bindLabelChip(chip){
  if (!chip) return;
  chip.addEventListener('click', () => handleLabelChipClick(chip));
}


