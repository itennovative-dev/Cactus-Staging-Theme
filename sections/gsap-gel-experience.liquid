function buildPaletteFromLabelRanges(labelRanges) {
  const out = [];
  for (const label in labelRanges) {
    const def = labelRanges[label];
    if (!def || def.type !== 'range') continue;
    const a = Number(def.a);
    const b = Number(def.b);

    let mid;
    if (a <= b) {
      mid = (a + b) / 2;
    } else {
      mid = ( (a + (b + 360)) / 2 ) % 360;
    }

    const span = a <= b ? (b - a) : (360 - a + b);

    out.push({ label, a, b, mid, span });
  }

  out.sort((x,y) => x.mid - y.mid);
  return out;
}

  function hueSort(a,b){
    if (a.hue == null && b.hue == null) return 0;
    if (a.hue == null) return 1;
    if (b.hue == null) return -1;
    return a.hue - b.hue;
  }
  
  const FILTER_COLOR_ORDER = [
    "Bordeaux",
    "Rosso",
    "Fucsia",
    "Rosa",
    "Viola",
    "Blu",
    "Azzurro",
    "Verde",
    "Giallo",
    "Arancione",
    "Marrone",
    "Nude",
    "Bianco",
    "Nero",
    "Grigio",
    "Argento",
    "Oro",
    "Lattiginoso",
    "Clear"
  ];
  
  function filterOrderSort(a, b) {
    const aColors = a.colors || [];
    const bColors = b.colors || [];
    
    const aLabel = aColors.length > 0 ? normalizeColorLabel(aColors[0]) : null;
    const bLabel = bColors.length > 0 ? normalizeColorLabel(bColors[0]) : null;
    
    if (!aLabel && !bLabel) return hueSort(a, b);
    if (!aLabel) return 1;
    if (!bLabel) return -1;
    
    const aIndex = FILTER_COLOR_ORDER.indexOf(aLabel);
    const bIndex = FILTER_COLOR_ORDER.indexOf(bLabel);
    
    if (aIndex !== -1 && bIndex !== -1) {
      return aIndex - bIndex;
    }
    
    if (aIndex !== -1) return -1;
    if (bIndex !== -1) return 1;
    
    return hueSort(a, b);
  }

