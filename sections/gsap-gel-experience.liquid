  (function initLongPress() {
    const backdrop   = document.getElementById('gel-preview-backdrop');
    const previewCard = document.getElementById('gel-preview-card');
    const thumbEl    = document.getElementById('gel-preview-thumb');
    const titleEl    = document.getElementById('gel-preview-title');
    const priceEl    = document.getElementById('gel-preview-price');
    const descEl     = document.getElementById('gel-preview-desc');
    const ctaEl      = document.getElementById('gel-preview-cta');

    if (!backdrop || !previewCard) return;

    const closeBtn = document.getElementById('gel-preview-close');
    if (closeBtn) {
      closeBtn.addEventListener('click', hidePreview, { passive: true });
    }

    function showPreview(it) {
      thumbEl.src = it.img1 || '';
      thumbEl.alt = it.title || '';
      titleEl.textContent = it.title || '';
      priceEl.textContent = it.price ? fmtMoney(it.price) : '';
      descEl.innerHTML = it.description || 'Nessuna descrizione disponibile.';
      ctaEl.href = '/products/' + (it.handle || '');

      // Resetta lo scroll della descrizione
      const body = previewCard.querySelector('.gel-preview-body');
      if (body) body.scrollTop = 0;

      backdrop.classList.add('is-on');
      previewCard.classList.add('is-on');
    }

    function hidePreview() {
      backdrop.classList.remove('is-on');
      previewCard.classList.remove('is-on');
    }

    // Chiudi con backdrop, ESC
    backdrop.addEventListener('click', hidePreview, { passive: true });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') hidePreview();
    }, { passive: true });

    // ── CLICK sulla card ──
    layer.addEventListener('click', (e) => {
      // Ignora click su bottoni (carrello, wishlist, X)
      if (e.target.closest('.gel-icon-btn')) return;

      const gelCard = e.target.closest('.gel-card');
      if (!gelCard || !gelCard._productData) return;

      // Se la modale è già aperta, la chiudiamo
      if (previewCard.classList.contains('is-on')) {
        hidePreview();
        return;
      }

      showPreview(gelCard._productData);
    });

  })();

});
